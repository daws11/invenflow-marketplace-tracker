{
  "name": "invenflow-marketplace-tracker",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hosted sidecar that scrapes Tokopedia/Shopee buyer dashboards and syncs orders into InvenFlow.",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\""
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.5.4"
  }
}
