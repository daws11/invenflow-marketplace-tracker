# =============================================================================
# InvenFlow Marketplace Tracker — environment variables (per PRD §14)
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# =============================================================================

# -----------------------------------------------------------------------------
# Public hostname & app URL
# -----------------------------------------------------------------------------
# Caddy uses DOMAIN to provision Let's Encrypt certs. For local dev, set to
# `localhost` (Caddy then serves plain HTTP on :80).
DOMAIN=tracker.example.com
APP_URL=https://tracker.example.com

# -----------------------------------------------------------------------------
# Datastore connections (internal Docker network — do NOT expose to the host)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://app:STRONG_PASSWORD@postgres:5432/app
DB_PASSWORD=STRONG_PASSWORD
REDIS_URL=redis://redis:6379

# -----------------------------------------------------------------------------
# Auth & encryption (sidecar-internal). Generate with: `openssl rand -base64 32`
# -----------------------------------------------------------------------------
NEXTAUTH_SECRET=replace-with-32-byte-base64
NEXTAUTH_URL=https://tracker.example.com
ENCRYPTION_KEY=replace-with-32-byte-base64

# -----------------------------------------------------------------------------
# WhatsApp notifications (Fonnte)
# -----------------------------------------------------------------------------
FONNTE_TOKEN=your-fonnte-token
ADMIN_WA_NUMBER=628xxxxxxxxxx

# -----------------------------------------------------------------------------
# AI provider — seed values only. Source-of-truth lives in the AiSettings table
# at runtime; nothing else in code references these strings.
# -----------------------------------------------------------------------------
INITIAL_AI_PROVIDER=anthropic
INITIAL_AI_MODEL=claude-sonnet-4-5
INITIAL_AI_API_KEY=sk-ant-xxx

# -----------------------------------------------------------------------------
# InvenFlow connection — base URL of the InvenFlow instance and a service
# token created at /settings/service-tokens with `marketplace.ingest`,
# `marketplace.transition`, and `upload` permissions.
# -----------------------------------------------------------------------------
INVENFLOW_BASE_URL=https://inv.example.com
INVENFLOW_INITIAL_SERVICE_TOKEN=inv_svc_xxx

# -----------------------------------------------------------------------------
# Initial admin (seeded on first boot — operator must change password on first
# login).
# -----------------------------------------------------------------------------
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=change-me-on-first-login

# -----------------------------------------------------------------------------
# Worker — X server display used by Xvfb + Chromium.
# -----------------------------------------------------------------------------
DISPLAY=:99
